APP_NAME="Teams Document Tracker"
ENVIRONMENT=local
# Local default works out of the box; replace with Supabase Postgres for deployment.
DATABASE_URL=sqlite:///./teams_tracker.db
# Example Supabase URL:
# DATABASE_URL=postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Microsoft Graph / Teams integration
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MS_WEBHOOK_CLIENT_STATE=

# Optional default channel to sync
MS_TEAM_ID=
MS_CHANNEL_ID=

# Firebase Cloud Messaging (native/browser push)
FCM_SERVER_KEY=
FCM_API_URL=https://fcm.googleapis.com/fcm/send