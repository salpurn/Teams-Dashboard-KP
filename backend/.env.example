APP_NAME="Teams Document Tracker"
ENVIRONMENT=local
DATABASE_URL=sqlite:///./teams_tracker.db

# Microsoft Graph / Teams integration
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MS_WEBHOOK_CLIENT_STATE=

# Optional default channel to sync
MS_TEAM_ID=
MS_CHANNEL_ID=

# Firebase Cloud Messaging (FCM HTTP v1 API)
# 1. Project ID: Firebase Console > Project settings > General > Project ID
# 2. Service account: Firebase Console > Project settings > Service accounts >
#    Generate new private key, lalu simpan file JSON-nya sebagai
#    backend/firebase-service-account.json (path bisa diubah lewat var di bawah)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=./firebase-service-account.json